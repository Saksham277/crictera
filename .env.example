# Copy this file to .env (or .env.local) and fill in your own values.
# Find these in your Supabase project: Project Settings -> API

# Project URL, e.g. https://abcdefghijk.supabase.co
VITE_SUPABASE_URL=

# anon / public key (safe to expose in client-side code — it only grants
# whatever access your Row Level Security policies allow, which is why the
# supabase_schema.sql policies matter)
VITE_SUPABASE_ANON_KEY=
